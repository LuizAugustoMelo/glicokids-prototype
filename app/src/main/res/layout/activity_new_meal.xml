<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/night">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvScreenTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Missão da Refeição"
            android:textColor="@android:color/white"
            android:textSize="21sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/btnBack"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            android:layout_marginStart="12dp" />

        <!-- Camera Placeholder Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPhoto"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="@color/white_alpha_20"
            app:cardCornerRadius="20dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/gold"
            app:layout_constraintTop_toBottomOf="@id/tvScreenTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivMealPhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_camera"
                android:alpha="0.6"
                android:padding="50dp" />
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnTakePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="📷 Fotografar o prato"
            android:backgroundTint="@color/gold"
            android:textColor="@color/ink"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardPhoto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvIaHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A IA estima os carboidratos (simulado no MVP)"
            android:textColor="@color/text_muted_dark"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/btnTakePhoto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Inputs Section -->
        <TextView
            android:id="@+id/lblCarbs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Carboidratos (g)"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvIaHint"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etCarbohydrates"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:hint="Ex: 45"
            android:textColorHint="@color/text_muted_light"
            android:textColor="@android:color/white"
            android:inputType="numberDecimal"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/lblCarbs" />

        <TextView
            android:id="@+id/lblGlucose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Glicemia atual (mg/dL)"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etCarbohydrates"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etCurrentGlucose"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:hint="Ex: 110"
            android:textColorHint="@color/text_muted_light"
            android:textColor="@android:color/white"
            android:inputType="number"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/lblGlucose" />

        <!-- 3D Action Button -->
        <Button
            android:id="@+id/btnCalculateBolus"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_marginTop="32dp"
            android:text="🚀 Calcular Bolus de Insulina"
            android:background="@drawable/bg_button_primary_3d"
            app:backgroundTint="@null"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/etCurrentGlucose"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Result Card -->
        <LinearLayout
            android:id="@+id/llResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_input_field"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/btnCalculateBolus"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tvCalculationResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dose sugerida: 3,5 UI"
                android:textColor="@color/teal"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="estimativa conservadora · confirme com um adulto"
                android:textColor="@color/text_muted_dark"
                android:textSize="11sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
