<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/lavender_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_white"
            android:src="@drawable/ic_back_ink"
            android:contentDescription="Voltar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvScreenTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Missão da Refeição"
            android:textColor="@color/ink"
            android:textSize="21sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="@id/btnBack" />

        <!-- Photo Selection Section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPhoto"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/white"
            app:layout_constraintTop_toBottomOf="@id/btnBack">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/ivMealPhoto"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_camera_custom"
                    android:alpha="0.3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:contentDescription="Foto do prato" />

                <Button
                    android:id="@+id/btnTakePhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:text="📷 Fotografar o prato"
                    android:backgroundTint="@color/gold"
                    android:textColor="@color/ink"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvIaHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A IA estima os carboidratos (simulado no MVP)"
            android:textColor="@color/text_muted_light"
            android:textSize="11sp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/cardPhoto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Inputs Section -->
        <TextView
            android:id="@+id/lblCarbs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Carboidratos (g)"
            android:textColor="@color/ink"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvIaHint"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etCarbohydrates"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_purple"
            android:hint="Ex: 45"
            android:textColorHint="@color/text_muted_light"
            android:textColor="@color/ink"
            android:inputType="numberDecimal"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/lblCarbs" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="estimado pela foto"
            android:textColor="@color/text_muted_light"
            android:textSize="12sp"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="@id/etCarbohydrates"
            app:layout_constraintTop_toTopOf="@id/etCarbohydrates"
            app:layout_constraintEnd_toEndOf="@id/etCarbohydrates" />

        <TextView
            android:id="@+id/lblGlucose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Glicemia atual (mg/dL)"
            android:textColor="@color/ink"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etCarbohydrates"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etCurrentGlucose"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_circle_white"
            android:elevation="0dp"
            android:hint="Ex: 110"
            android:textColorHint="@color/text_muted_light"
            android:textColor="@color/ink"
            android:inputType="number"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/lblGlucose" />

        <!-- 3D Action Button -->
        <Button
            android:id="@+id/btnCalculateBolus"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_marginTop="32dp"
            android:text="🚀 Calcular Bolus de Insulina"
            android:background="@drawable/bg_button_primary_3d"
            app:backgroundTint="@null"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/etCurrentGlucose"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Result Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/llResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:cardCornerRadius="22dp"
            app:cardBackgroundColor="#E0F2F1"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/teal"
            app:layout_constraintTop_toBottomOf="@id/btnCalculateBolus"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvCalculationResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dose sugerida: 3,5 UI"
                    android:textColor="@color/teal_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="estimativa conservadora · confirme com um adulto"
                    android:textColor="@color/text_muted_light"
                    android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
