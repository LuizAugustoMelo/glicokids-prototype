<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_success">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvMascot"
        android:layout_width="170dp" android:layout_height="170dp"
        app:cardCornerRadius="85dp" app:cardElevation="10dp"
        app:cardBackgroundColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.22">
        <ImageView
            android:id="@+id/ivMascot"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:padding="24dp" android:src="@drawable/ic_avatar_1"
            android:contentDescription="Glico comemorando"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvRewardTitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Missão cumprida,\nLucas!"
        android:textAlignment="center"
        android:textColor="@android:color/white" android:textSize="30sp" android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/cvMascot"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/llBonuses"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="18dp" android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvRewardTitle"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:id="@+id/tvXpGain"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_glass_card"
            android:paddingHorizontal="16dp" android:paddingVertical="10dp"
            android:text="+25 XP" android:textColor="@color/gold" android:textSize="15sp" android:textStyle="bold"/>
        <TextView
            android:id="@+id/tvCoinGain"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:paddingHorizontal="16dp" android:paddingVertical="10dp"
            android:text="+10 moedas" android:textColor="@color/gold" android:textSize="15sp" android:textStyle="bold"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvStreak"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_button_gold_3d"
        android:paddingHorizontal="18dp" android:paddingVertical="8dp"
        android:text="★ 5 dias seguidos na meta!"
        android:textColor="#4A3400" android:textSize="13sp" android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/llBonuses"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnBackToBase"
        android:layout_width="wrap_content" android:layout_height="60dp"
        android:layout_marginTop="44dp"
        android:paddingHorizontal="40dp"
        android:background="@drawable/bg_button_white_3d" app:backgroundTint="@null"
        android:text="Voltar à base 🚀" android:textAllCaps="false"
        android:textColor="#00785B" android:textSize="16sp" android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvStreak"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
