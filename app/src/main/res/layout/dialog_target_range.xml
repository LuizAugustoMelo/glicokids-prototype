<?xml version="1.0" encoding="utf-8"?>
<!-- b18 · Conteúdo do MaterialAlertDialog da Faixa alvo. Validação no código: 40 <= min < max <= 300 e min < alvo < max. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp" android:paddingTop="8dp">

    <TextView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Define quando o Glico mostra “na meta”. Confirme os valores com o médico da criança."
        android:textColor="@color/text_muted_light" android:textSize="13sp"
        android:lineSpacingMultiplier="1.2"/>

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="16dp" android:orientation="horizontal" android:baselineAligned="false">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRangeMin"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:hint="Mínimo" app:suffixText="mg/dL"
            app:boxStrokeColor="@color/primary" app:hintTextColor="@color/primary_dark">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRangeMin"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="number" android:maxLength="3"
                android:textColor="@color/ink" android:textStyle="bold" android:text="70"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center_vertical" android:paddingHorizontal="10dp"
            android:text="–" android:textColor="@color/text_muted_light" android:textSize="18sp" android:textStyle="bold"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRangeMax"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:hint="Máximo" app:suffixText="mg/dL"
            app:boxStrokeColor="@color/primary" app:hintTextColor="@color/primary_dark">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRangeMax"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="number" android:maxLength="3"
                android:textColor="@color/ink" android:textStyle="bold" android:text="180"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="aceito: 40 ≤ mín &lt; máx ≤ 300"
        android:textColor="@color/text_muted_light" android:textSize="12sp"/>
</LinearLayout>
