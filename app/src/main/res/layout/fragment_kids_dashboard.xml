<?xml version="1.0" encoding="utf-8"?>
<!-- b7/b8 · Home da criança. SUBSTITUI o arquivo do staging.
     Correções vs app atual: fundo gradiente+estrelas, header em UMA linha (avatar·nome/XP·moedas·menu),
     card de glicemia GLASS (nunca teal sólido; elevation 0 evita tonal overlay), chip "estável" teal sólido legível. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@drawable/bg_night_stars"
    android:padding="20dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="1dp" android:layout_height="1dp"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>

    <!-- Header: tudo em UMA linha -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvAvatar"
        android:layout_width="56dp" android:layout_height="56dp"
        app:cardCornerRadius="28dp" app:cardElevation="0dp"
        app:strokeWidth="2dp" app:strokeColor="@color/gold"
        app:cardBackgroundColor="@color/night_mid"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent">
        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:padding="4dp" android:src="@drawable/ic_avatar_1"
            android:contentDescription="Avatar do Glico"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Oi, Lucas!" android:textColor="@android:color/white"
        android:textSize="21sp" android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/cvAvatar"
        app:layout_constraintStart_toEndOf="@id/cvAvatar"
        app:layout_constraintEnd_toStartOf="@id/cvCoins"/>

    <ProgressBar
        android:id="@+id/pbXp"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="100dp" android:layout_height="8dp"
        android:layout_marginStart="12dp" android:layout_marginTop="4dp"
        android:progress="70" android:progressTint="@color/teal"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome"
        app:layout_constraintStart_toEndOf="@id/cvAvatar"/>

    <TextView
        android:id="@+id/tvLevel"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="Nv 7" android:textColor="@color/text_muted_dark" android:textSize="12sp"
        app:layout_constraintTop_toTopOf="@id/pbXp" app:layout_constraintBottom_toBottomOf="@id/pbXp"
        app:layout_constraintStart_toEndOf="@id/pbXp"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvCoins"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        app:cardBackgroundColor="@color/white_alpha_20"
        app:cardCornerRadius="20dp" app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="@id/cvAvatar" app:layout_constraintBottom_toBottomOf="@id/cvAvatar"
        app:layout_constraintEnd_toStartOf="@id/btnMenu">
        <TextView
            android:id="@+id/tvCoins"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:paddingHorizontal="12dp" android:paddingVertical="6dp"
            android:text="230" android:textColor="@android:color/white" android:textStyle="bold"
            android:drawablePadding="6dp"
            app:drawableStartCompat="@drawable/ic_coin_star"/>
    </com.google.android.material.card.MaterialCardView>

    <ImageButton
        android:id="@+id/btnMenu"
        android:layout_width="48dp" android:layout_height="48dp"
        android:background="@drawable/bg_glass_card"
        android:src="@drawable/ic_menu_more_custom"
        android:contentDescription="Menu de opções"
        app:layout_constraintTop_toTopOf="@id/cvAvatar" app:layout_constraintBottom_toBottomOf="@id/cvAvatar"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Card de glicemia: GLASS escuro com stroke teal (NUNCA fundo teal sólido) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardGlucose"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/white_alpha_20"
        app:cardCornerRadius="24dp" app:cardElevation="0dp"
        app:strokeWidth="1.5dp" app:strokeColor="@color/teal"
        app:layout_constraintTop_toBottomOf="@id/cvAvatar">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:padding="20dp">
            <TextView
                android:id="@+id/tvGlucoseValue"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="112" android:textColor="@color/teal_glow"
                android:textSize="32sp" android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
            <TextView
                android:id="@+id/tvGlucoseStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="mg/dL · Na meta!" android:textColor="@android:color/white" android:textSize="14sp" android:textStyle="bold"
                app:layout_constraintTop_toTopOf="@id/tvGlucoseValue"
                app:layout_constraintStart_toEndOf="@id/tvGlucoseValue"/>
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Glico está orbitando feliz" android:textColor="@color/text_muted_dark" android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/tvGlucoseStatus"
                app:layout_constraintStart_toStartOf="@id/tvGlucoseStatus"/>
            <TextView
                android:id="@+id/tvTrend"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_teal_solid"
                android:paddingHorizontal="12dp" android:paddingVertical="5dp"
                android:text="→ estável" android:textColor="@color/night_deep" android:textSize="12sp" android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Botão-foguete central -->
    <View
        android:id="@+id/vOrbit"
        android:layout_width="240dp" android:layout_height="240dp"
        android:background="@drawable/bg_dotted_ring"
        app:layout_constraintTop_toBottomOf="@id/cardGlucose"
        app:layout_constraintBottom_toTopOf="@id/tvHint"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnNewMeal"
        android:layout_width="200dp" android:layout_height="200dp"
        android:clickable="true" android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardCornerRadius="100dp" app:cardBackgroundColor="@color/teal" app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="@id/vOrbit" app:layout_constraintBottom_toBottomOf="@id/vOrbit"
        app:layout_constraintStart_toStartOf="@id/vOrbit" app:layout_constraintEnd_toEndOf="@id/vOrbit">
        <LinearLayout
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:orientation="vertical" android:gravity="center">
            <ImageView
                android:layout_width="56dp" android:layout_height="56dp"
                android:src="@drawable/ic_camera_custom" app:tint="@color/night_deep"
                android:contentDescription="Iniciar Missão"/>
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="MISSÃO DA\nREFEIÇÃO" android:textAlignment="center"
                android:textColor="@color/night_deep" android:textSize="18sp" android:textStyle="bold"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Fotografe seu prato e lance o foguete!"
        android:textColor="@color/text_muted_dark" android:textSize="13sp"
        app:layout_constraintBottom_toTopOf="@id/llBottomButtons"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/llBottomButtons"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btnParentArea">
        <Button
            android:id="@+id/btnMissions"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="80dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_button_gold_3d" app:backgroundTint="@null"
            android:text="⬢ Missões\n2 ativas hoje" android:textAllCaps="false"
            android:textColor="@color/ink" android:textSize="14sp"/>
        <Button
            android:id="@+id/btnMedals"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="80dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_button_white_3d" app:backgroundTint="@null"
            android:text="★ Medalhas\n12 conquistadas" android:textAllCaps="false"
            android:textColor="@color/primary" android:textSize="14sp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnParentArea"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:text="🔒 Área dos Pais" android:textAllCaps="false"
        android:textColor="@color/text_muted_dark" android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
