<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/night_deep"
    android:padding="20dp">

    <!-- Header Section -->
    <ImageView
        android:id="@+id/ivAvatar"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@android:drawable/btn_star_big_on"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Oi, Lucas!"
        android:textColor="@android:color/white"
        android:textSize="21sp"
        android:textStyle="bold"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toTopOf="@id/ivAvatar"
        app:layout_constraintStart_toEndOf="@id/ivAvatar" />

    <ProgressBar
        android:id="@+id/pbXp"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="120dp"
        android:layout_height="8dp"
        android:progress="70"
        android:progressTint="@color/teal"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome"
        app:layout_constraintStart_toStartOf="@id/tvWelcome" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lv 7"
        android:textColor="@color/text_muted_dark"
        android:textSize="12sp"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toEndOf="@id/pbXp"
        app:layout_constraintTop_toTopOf="@id/pbXp"
        app:layout_constraintBottom_toBottomOf="@id/pbXp" />

    <TextView
        android:id="@+id/tvCoins"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💰 230"
        android:background="@drawable/bg_glass_card"
        android:textColor="@android:color/white"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Glucose Card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardGlucose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_glass_card"
        android:backgroundTint="@color/teal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/ivAvatar">

        <TextView
            android:id="@+id/tvGlucoseValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="112"
            android:textColor="@android:color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvGlucoseStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="mg/dL · Na meta!"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="@id/tvGlucoseValue"
            app:layout_constraintStart_toEndOf="@id/tvGlucoseValue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Glico está orbitando feliz"
            android:textColor="@color/white_alpha_20"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tvGlucoseStatus"
            app:layout_constraintStart_toStartOf="@id/tvGlucoseStatus" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="→ estável"
            android:background="@drawable/bg_glass_card"
            android:textColor="@color/teal"
            android:backgroundTint="@android:color/white"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textSize="12sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Main Circular Button -->
    <FrameLayout
        android:id="@+id/btnNewMeal"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_circle_teal"
        app:layout_constraintTop_toBottomOf="@id/cardGlucose"
        app:layout_constraintBottom_toTopOf="@+id/llBottomButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="@color/night_deep" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MISSÃO DA\nREFEIÇÃO"
                android:textAlignment="center"
                android:textColor="@color/night_deep"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fotografe seu prato e lance o foguete!"
        android:textColor="@color/text_muted_dark"
        android:textSize="13sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnNewMeal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/llBottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/btnParentArea">

        <Button
            android:id="@+id/btnMissions"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="80dp"
            android:text="⬢ Missões\n2 ativas hoje"
            android:background="@drawable/bg_button_gold_3d"
            app:backgroundTint="@null"
            android:textColor="@color/ink"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnMedals"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="80dp"
            android:text="★ Medalhas\n12 conquistadas"
            android:background="@drawable/bg_glass_card"
            android:backgroundTint="@android:color/white"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnParentArea"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒 Área dos Pais"
        android:background="@drawable/bg_glass_card"
        android:textColor="@color/text_muted_dark"
        android:textAllCaps="false"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
